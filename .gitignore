# .devcontainer codespace environment
.devcontainer/

# Local .terraform directories
**/.terraform/

# .tfstate files (This is the most important for security!)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
# These are like .env files and must NEVER be committed to GitHub
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files
.terraform.tfstate.lock.info

# --- ESWAP SPECIFIC ADDITIONS ---

# Ignore generated Plan files (Binary files from 'terraform plan -out=...')
*.tfplan

# Ignore Mac system files (if you or a teammate ever use a Mac)
.DS_Store

# Ignore sensitive AWS credentials (just in case)
.aws/
credentials
# --------------------------------

# Ignore CLI configuration files
.terraformrc
terraform.rc